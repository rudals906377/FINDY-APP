FINDY_AUTH_PUBLIC_URL=https://auth.example.com
FINDY_AUTH_DATABASE_PATH=./findy_auth.db
FINDY_AUTH_FLOW_TTL_SECONDS=300
FINDY_AUTH_ENV=development

# 휴대폰 문자 인증
FINDY_OTP_TTL_SECONDS=180
FINDY_OTP_RESEND_SECONDS=60
FINDY_OTP_MAX_ATTEMPTS=5
FINDY_OTP_SECRET=replace-with-a-long-random-secret
FINDY_SMS_PROVIDER=console
# FINDY_SMS_PROVIDER=webhook
# FINDY_SMS_WEBHOOK_URL=https://sms.example.com/send
# FINDY_SMS_WEBHOOK_TOKEN=

# PASS 본인확인 계약 후 NICE, KCB, DANAL, KCP 등의 어댑터를 지정합니다.
FINDY_IDENTITY_PROVIDER=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
